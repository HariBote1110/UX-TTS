<!DOCTYPE html>
<html lang="ja" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>サーバー選択 - UX TTS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #2b2d31;
            color: white;
            min-height: 100vh;
        }

        .container {
            padding-top: 40px;
            padding-bottom: 40px;
        }

        .server-card {
            background-color: #313338;
            border: none;
            transition: transform 0.2s, background-color 0.2s;
            text-decoration: none;
            color: white;
            border-radius: 12px;
        }

        .server-card:hover {
            transform: translateY(-5px);
            background-color: #404249;
            color: white;
        }

        .server-icon {
            width: 80px;
            height: 80px;
            object-fit: cover;
            background-color: #1e1f22;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 15px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        }

        @media (max-width: 576px) {
            .container {
                padding-top: 20px;
            }

            .server-icon {
                width: 64px;
                height: 64px;
                font-size: 1.2rem;
            }

            .card-title {
                font-size: 1rem;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-5 border-bottom border-secondary pb-3">
            <h5 class="m-0 text-truncate"><i class="bi bi-person-circle me-2"></i>
                <%= user.username %>
            </h5>
            <a href="/auth/logout" class="btn btn-sm btn-outline-danger"><i
                    class="bi bi-box-arrow-right me-1"></i>ログアウト</a>
        </div>

        <% if (messages.success) { %>
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <%= messages.success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>
                <% if (messages.error) { %>
                    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <%= messages.error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <h4 class="mb-4 text-light text-center text-md-start"><i
                                class="bi bi-grid-fill me-2"></i>サーバーを選択</h4>

                        <% if (guilds.length===0) { %>
                            <div class="text-center text-secondary py-5">
                                <i class="bi bi-server display-4 mb-3 d-block"></i>
                                <p>管理可能なサーバーが見つかりませんでした。</p>
                            </div>
                            <% } else { %>
                                <div class="row g-3 g-md-4">
                                    <% guilds.forEach(guild=> { %>
                                        <div class="col-6 col-md-4 col-lg-3">
                                            <a href="/dashboard/<%= guild.id %>"
                                                class="card server-card h-100 py-4 shadow-sm">
                                                <div class="card-body text-center p-2">
                                                    <% if (guild.icon) { %>
                                                        <img src="<%= guild.icon %>" class="rounded-circle server-icon"
                                                            alt="<%= guild.name %>">
                                                        <% } else { %>
                                                            <div class="rounded-circle server-icon text-white">
                                                                <%= guild.name.substring(0,1) %>
                                                            </div>
                                                            <% } %>
                                                                <h6 class="card-title text-truncate px-1 mb-1">
                                                                    <%= guild.name %>
                                                                </h6>
                                                                <% if (!guild.isAdmin) { %>
                                                                    <span class="badge bg-secondary"
                                                                        style="font-size:0.65rem;">管理権限なし</span>
                                                                    <% } %>
                                                </div>
                                            </a>
                                        </div>
                                        <% }); %>
                                </div>
                                <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>