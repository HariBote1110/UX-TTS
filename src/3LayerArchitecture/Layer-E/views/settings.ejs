<!DOCTYPE html>
<html lang="ja" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>設定 - <%= selectedGuild.name %>
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background-color: #2b2d31;
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        }

        /* サイドバー (デスクトップ用) */
        .sidebar-desktop {
            background-color: #1e1f22;
            min-height: 100vh;
            padding: 20px;
            width: 280px;
            position: fixed;
            top: 0;
            left: 0;
            overflow-y: auto;
            z-index: 1000;
        }

        /* コンテンツエリア (デスクトップ用) */
        .content {
            padding: 30px;
            margin-left: 280px;
        }

        /* モバイル対応 */
        @media (max-width: 768px) {
            .sidebar-desktop {
                display: none;
            }

            .content {
                margin-left: 0;
                padding: 15px;
                margin-top: 60px;
            }
        }

        /* 共通スタイル */
        .card {
            background-color: #313338;
            border: none;
            margin-bottom: 20px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
        }

        .card-header {
            background-color: #2b2d31;
            border-bottom: 1px solid #1e1f22;
            font-weight: bold;
        }

        .form-control,
        .form-select {
            background-color: #1e1f22;
            border: none;
            color: #dbdee1;
        }

        .form-control:focus,
        .form-select:focus {
            background-color: #1e1f22;
            color: #fff;
            box-shadow: none;
            border: 1px solid #5865F2;
        }

        .btn-primary {
            background-color: #5865F2;
            border: none;
        }

        .btn-primary:hover {
            background-color: #4752c4;
        }

        .nav-pills .nav-link {
            color: #dbdee1;
            border-radius: 4px;
            margin-bottom: 5px;
            cursor: pointer;
        }

        .nav-pills .nav-link.active {
            background-color: #404249;
            color: #fff;
        }

        .admin-badge {
            background-color: #da373c;
            color: white;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 0.7em;
            vertical-align: middle;
        }

        .table {
            --bs-table-bg: transparent;
            --bs-table-color: #dbdee1;
        }

        .table td,
        .table th {
            border-color: #1e1f22;
            vertical-align: middle;
        }

        .progress {
            background-color: #1e1f22;
            height: 25px;
        }
    </style>
</head>

<body>

    <nav class="navbar navbar-dark bg-dark fixed-top d-md-none shadow">
        <div class="container-fluid">
            <button class="navbar-toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <span class="navbar-brand mb-0 h1 text-truncate" style="max-width: 70%;">
                <%= selectedGuild.name %>
            </span>
        </div>
    </nav>

    <div class="sidebar-desktop d-none d-md-block">
        <h4 class="mb-4 text-white text-truncate">
            <% if (selectedGuild.icon) { %>
                <img src="<%= selectedGuild.icon %>" width="32" height="32" class="rounded-circle me-2" alt="">
                <% } else { %>
                    <div class="d-inline-block rounded-circle bg-secondary text-white text-center me-2"
                        style="width:32px; height:32px; line-height:32px;">
                        <%= selectedGuild.name.substring(0,1) %>
                    </div>
                    <% } %>
                        <%= selectedGuild.name %>
        </h4>
        <%- include('partials/sidebar_menu') %>
    </div>

    <div class="offcanvas offcanvas-start text-bg-dark" tabindex="-1" id="mobileSidebar">
        <div class="offcanvas-header border-bottom border-secondary">
            <h5 class="offcanvas-title text-truncate">
                <% if (selectedGuild.icon) { %>
                    <img src="<%= selectedGuild.icon %>" width="24" height="24" class="rounded-circle me-2" alt="">
                    <% } %>
                        <%= selectedGuild.name %>
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <%- include('partials/sidebar_menu') %>
        </div>
    </div>

    <div class="content">

        <% if (messages.error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <%= messages.error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>
                <% if (messages.success) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <%= messages.success %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                    <% } %>

                        <div class="tab-content" id="v-pills-tabContent">
                            <%- include('partials/tab_general') %>
                                <%- include('partials/tab_user_dictionary') %>
                                <%- include('partials/tab_dictionary') %>
                                    <%- include('partials/tab_autojoin') %>
                                        <%- include('partials/tab_usage') %>
                        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // --- モバイルメニュー ---
        function closeMobileMenu() {
            const mobileMenuEl = document.getElementById('mobileSidebar');
            const mobileMenu = bootstrap.Offcanvas.getInstance(mobileMenuEl);
            if (mobileMenu) mobileMenu.hide();
        }

        // --- タブ制御 ---
        const hash = window.location.hash;
        if (hash) {
            const triggerEl = document.querySelector(`button[data-bs-target="#content-${hash.substring(1)}"]`);
            if (triggerEl) {
                const tab = new bootstrap.Tab(triggerEl);
                tab.show();
            }
        }
    </script>
</body>

</html>